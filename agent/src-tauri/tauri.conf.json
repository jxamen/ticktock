{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TickTock",
  "version": "0.1.0",
  "identifier": "com.ticktock.agent",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "tray",
        "title": "TickTock",
        "width": 360,
        "height": 420,
        "visible": false,
        "decorations": true,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico", "icons/icon.png"],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine",
        "installerHooks": "installer-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU0RTAyQzdDQTAwQ0E3NEEKUldSS3B3eWdmQ3pnNVBIZEI0Tml0aVNYbGViT3grT0orUXpLdi9EamJuTHVoa0JMTkNBYk01Y3cK",
      "endpoints": [
        "https://github.com/OWNER_PLACEHOLDER/ticktock/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
